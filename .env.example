# API
APP_ENVIRONMENT=local
APP_LOG_LEVEL=INFO
APP_SERVICE_NAME=edd-api
APP_STORAGE_BACKEND=memory
APP_DATABASE_URL=postgresql+asyncpg://edd:edd@localhost:5433/edd
APP_AUTO_CREATE_SCHEMA=false
APP_AUTH_ENABLED=false
APP_AUTH_ISSUER=edd-api
APP_AUTH_AUDIENCE=edd-api
APP_AUTH_DEMO_SECRET=local-demo-secret
APP_OTEL_ENABLED=true
APP_OTEL_EXPORTER=none
APP_CORS_ALLOWED_ORIGINS=["http://localhost:8501","http://127.0.0.1:8501"]

# Console
EDD_API_BASE_URL=http://localhost:8000

# Worker
# APP_SERVICE_NAME=edd-worker

# Langfuse (optional — Phase 4+)
LANGFUSE_ENABLED=false
LANGFUSE_HOST=http://localhost:3001
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_PROJECT_NAME=local-demo
